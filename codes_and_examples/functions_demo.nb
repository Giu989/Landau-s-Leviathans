      RowBox[{"x2", " ", "x3"}], "+", 
      RowBox[{"s", " ", "x1", " ", "x2", " ", "x3"}], "-", 
      RowBox[{"m2", " ", 
       RowBox[{"(", 
        RowBox[{"x1", "+", "x2", "+", "x3"}], ")"}], 
