      RowBox[{"x1", " ", "x2"}], "+", 
      RowBox[{"x1", " ", "x3"}], "+", 
      RowBox[{"x2", " ", "x3"}], "+", 
      RowBox[{"s", " ", "x1", " ", "x2", " ", "x3"}], "-", 
      RowBox[{"m2", " ", 
       RowBox[{"(", 
        RowBox[{"x1", "+", "x2", "+", "x3"}], ")"}], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"x2", " ", "x3"}], "+", 
         RowBox[{"x1", " ", "x2"}], "+", 
         RowBox[{"x1", " ", "x3"}]}], ")"}]}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"vars", "=", 
     RowBox[{"{", 
      RowBox[{"x1", ",", "x2", ",", "x3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"SPQRLandau", "[", 
    RowBox[{"G", ",", "vars"}], "]"}]}]}]], "Input",
