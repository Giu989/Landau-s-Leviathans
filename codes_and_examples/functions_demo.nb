   RowBox[{
    RowBox[{"vars", "=", 
     RowBox[{"{", 
      RowBox[{"x1", ",", "x2", ",", "x3"}], "}"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"SPQRLandau", "[", 
    RowBox[{"G", ",", "vars"}], "]"}]}]}]], "Input",
